# Copy to config.env and fill in. Loaded by SLURM scripts and data_prep/download_data.sh.
#
#   cp config.env.example config.env
#   $EDITOR config.env
#   source config.env

# Working data directory (predictions, intermediate outputs, downloads).
# All SLURM scripts read/write under ${DATA_DIR}.
DATA_DIR=/path/to/your/working/data/dir

# Your home dir on the cluster (used by a few wrappers that expect $HOME-style paths).
USER_HOME=$HOME

# Conda base + env name. SLURM scripts run `source ${CONDA_BASE}/etc/profile.d/conda.sh`
# then `conda activate ${CONDA_ENV}`. The env is built from `environment.yml`.
CONDA_BASE=$HOME/miniconda3
CONDA_ENV=pfp

# External sibling repos. Clone these alongside this repo and point the variables.
#   git clone https://github.com/bio-ontology-research-group/GAEF
#   git clone https://github.com/bio-ontology-research-group/deepgo2
#   git clone https://github.com/biomed-AI/SPROF-GO
GAEF_DIR=/path/to/GAEF
DEEPGO_SE_REPO=/path/to/deepgo2
SPROF_GO_REPO=/path/to/SPROF-GO

# GO ontology file (fetched by data_prep/download_data.sh).
GO_OBO=${PWD}/data/go-basic.obo
