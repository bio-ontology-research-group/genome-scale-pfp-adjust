# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/

# Virtual envs / local config
.env
.venv/
env/
config.env

# Editor / OS
.DS_Store
.idea/
*~

# Large data / artifacts that must NOT be committed
*.pkl
*.faa
*.fasta
*.fa
*.dat
*.dat.gz
*.gz
*.zip
*.tar
*.npz
*.npy
*.th
*.pt
*.ckpt
*.bin
*.log
*.bak

# Local results / intermediate outputs (regenerated by the pipeline)
results/
logs/
outputs/
swissprot_folds_*/
uniprot_proteomes_folds/
eval_gaef_*_results/
term-centric-analysis*/
term-flip-ranking/
adjustments_debug_/
demos/*/output/

# Bundled-data exceptions: these large/binary file types are explicitly ALLOWED
# under data/, splits/, accession_lists/, and complex_coherence/.
!data/*.tsv
!data/*.obo
!splits/**/*.tsv
!splits/**/*.json
!splits/**/*.txt
!accession_lists/*.tsv
!complex_coherence/*.tsv
!tests/fixtures/*.tsv

# Downloaded by data_prep/download_data.sh, not committed
data/go-basic.obo
data/ncbitaxon.obo
data/ncbitaxon_hierarchy.tsv
